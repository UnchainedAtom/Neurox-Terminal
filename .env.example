# Home Assistant Configuration
HOME_ASSISTANT_URL=http://neuroxnode-terminal:8123
HOME_ASSISTANT_TOKEN=your_access_token_here

# Light Entity Configuration
LIGHT_ENTITY_ID=light.overhead_light

# Media configuration
MEDIA_PATH=/home/pi/media.mp4

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=8000

# Demo/Mock Mode
# Set to True for testing without Home Assistant
# Home Assistant is not currently supported in this version, so this should be set to True for now
DEMO_MODE=True
